#: ../Onboard/Appearance.py:130
#, python-brace-format
msgid "Color scheme for theme '{filename}' not found"
msgstr "ཁ་བྱང་ '{filename}' གི་ཚོས་གཞི་ཐིག་དྲིལ་རྙེད་མ་སོང་།"

